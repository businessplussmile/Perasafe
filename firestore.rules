rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitive Definitions ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth role lookup (Trusted DB source)
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isAdmin() {
      // Direct email check for the app owner and role check for scalability
      return isSignedIn() && (
        request.auth.token.email == 'jorisahoussi4@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    function isNotBlocked() {
       return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              (!('isBlocked' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == false);
    }
    
    function canAccess() {
       return isSignedIn() && isNotBlocked();
    }

    // --- PHASE 4: Entity Match Blocks ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
               data.keys().size() <= 20 &&
               data.uid == userId && // Ensure UID matches document ID
               data.email is string &&
               data.role in ['ADMIN', 'COMPANY_OWNER', 'PARTNER'] &&
               data.createdAt is number &&
               (!('isBlocked' in data) || data.isBlocked is bool) &&
               (!('subscriptionTier' in data) || data.subscriptionTier in ['STANDARD', 'PRO', 'BUSINESS']) &&
               (!('subscriptionStatus' in data) || data.subscriptionStatus in ['NONE', 'PENDING', 'ACTIVE']) &&
               (!('subscriptionExpiresAt' in data) || data.subscriptionExpiresAt is number) &&
               (!('hasSeenAdminTour' in data) || data.hasSeenAdminTour is bool) &&
               (!('hasSeenUserTour' in data) || data.hasSeenUserTour is bool) &&
               (!('onboardingCompleted' in data) || data.onboardingCompleted is bool);
      }

      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && (
                       (request.auth.uid == userId && isNotBlocked() &&
                        incoming().uid == existing().uid &&
                        incoming().email == existing().email &&
                        (incoming().role == existing().role || (existing().role == 'COMPANY_OWNER' && incoming().role == 'PARTNER')) && 
                        !('isBlocked' in incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'companyId', 'subscriptionStatus', 'requestedTier', 'onboardingData', 'onboardingCompleted', 'subscriptionTier', 'subscriptionExpiresAt', 'role', 'hasSeenAdminTour', 'hasSeenUserTour']) &&
                        // Logic guards for self-updates
                        (incoming().subscriptionStatus in ['NONE', 'PENDING'] || (incoming().role == 'PARTNER' && incoming().subscriptionStatus == 'ACTIVE') || isAdmin())
                       ) || isAdmin()
                     );
      allow delete: if isAdmin();
    }

    // 2. Companies Collection
    match /companies/{companyId} {
      allow get, list: if canAccess() || isAdmin(); 
      
      function isValidCompany(data) {
        return data.keys().hasAll(['id', 'name', 'ownerId', 'subscriptionStatus', 'createdAt']) &&
               data.id == companyId &&
               data.name is string && data.name.size() <= 200 &&
               data.subscriptionStatus in ['ACTIVE', 'INACTIVE', 'TRIAL'] &&
               data.createdAt is number;
      }

      allow create: if canAccess() && isValidId(companyId) && isValidCompany(incoming());
      allow update: if (canAccess() || isAdmin()) && (existing().ownerId == request.auth.uid || isAdmin()) && 
                       incoming().id == existing().id &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'subscriptionStatus', 'subscriptionTier', 'subscriptionExpiry']);
      allow delete: if isAdmin() || (canAccess() && existing().ownerId == request.auth.uid);
    }

    // 3. Documents Sub-collection
    match /companies/{companyId}/documents/{docId} {
      function isCompanyOwner() {
        return canAccess() && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
      }

      function isPartner() {
        return canAccess() && request.auth.token.email in existing().partnerIds;
      }

      allow get: if isValidId(companyId) && isValidId(docId) && (isCompanyOwner() || isPartner() || isAdmin());
      allow list: if isValidId(companyId) && (isCompanyOwner() || isAdmin());

      function isValidDoc(data) {
        let tier = getUserData(request.auth.uid).subscriptionTier;
        let limit = (tier == 'BUSINESS') ? 100 : (tier == 'PRO' ? 10 : 1);
        
        return data.keys().hasAll(['id', 'title', 'content', 'accessCode', 'companyId', 'createdAt', 'uploaderId']) &&
               data.id == docId &&
               data.title is string && data.title.size() <= 200 &&
               data.content is string && data.content.size() <= 1048576 &&
               data.accessCode is string && data.accessCode.size() <= 256 &&
               data.companyId == companyId &&
               data.uploaderId == request.auth.uid &&
               data.partnerIds is list && data.partnerIds.size() > 0 && data.partnerIds.size() <= limit &&
               data.createdAt is number &&
               (!('lifespanStart' in data) || data.lifespanStart == null || data.lifespanStart is number) &&
               (!('lastCodeUsedAtOpening' in data) || data.lastCodeUsedAtOpening == null || data.lastCodeUsedAtOpening is string) &&
               (!('validityDuration' in data) || data.validityDuration is number);
      }

      allow create: if canAccess() && isValidId(companyId) && isValidId(docId) && isCompanyOwner() && isValidDoc(incoming());
      
      allow update: if (isCompanyOwner() || isPartner() || isAdmin()) && 
                       isValidId(companyId) && isValidId(docId) &&
                       (
                         isAdmin() || 
                         // Partner can only update 'lifespanStart' and 'lastCodeUsedAtOpening'
                         (isPartner() && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['lifespanStart', 'lastCodeUsedAtOpening']) &&
                          (!('lifespanStart' in incoming()) || incoming().lifespanStart == null || incoming().lifespanStart is number) &&
                          (!('lastCodeUsedAtOpening' in incoming()) || incoming().lastCodeUsedAtOpening == null || incoming().lastCodeUsedAtOpening is string)
                         ) ||
                         // Owner update requires full validation
                         (isCompanyOwner() && 
                          isValidDoc(incoming()) &&
                          incoming().id == existing().id &&
                          incoming().companyId == existing().companyId &&
                          incoming().createdAt == existing().createdAt &&
                          incoming().uploaderId == existing().uploaderId &&
                          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'accessCode', 'isConsumed', 'partnerIds', 'lifespanStart', 'lastCodeUsedAtOpening', 'validityDuration'])
                         )
                       );

      allow delete: if (isValidId(companyId) && isCompanyOwner()) || isAdmin();
    }

    // 4. Secure List Queries for Partners (Collection Group)
    match /{path=**}/documents/{docId} {
      // Allows collectionGroup queries like: db.collectionGroup('documents').where('partnerIds', 'array-contains', userEmail)
      allow list: if canAccess() && request.auth.token.email in resource.data.partnerIds;
    }
  }
}
